@{
}
@model IEnumerable<Clase6.EF.Entidades.Juguete>

<h1>Juguetes</h1>
<table class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Edad Recomendada</th>
            <th>Eliminar</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var juguete in Model)
        {
            <tr>
                <td>@juguete.Nombre</td>
                <td>@juguete.Precio</td>
                <td>@juguete.EdadRecomendada</td>
                <td><a href="/juguetes/eliminar/@juguete.Id">Eliminar</a></td>
            </tr>
        }
    </tbody>
</table>
