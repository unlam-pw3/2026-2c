@{
}
@model Clase6.EF.Web.Models.JugueteViewModel

<h2>Editar Juguete</h2>

<form asp-action="Editar" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Nombre"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Precio"></label>
        <input asp-for="Precio" class="form-control" />
        <span asp-validation-for="Precio" class="text-danger"></span>
    </div>
    @* EdadRecomendada *@
    <div class="form-group">
        <label asp-for="EdadRecomendada"></label>
        <input asp-for="EdadRecomendada" class="form-control" />
        <span asp-validation-for="EdadRecomendada" class="text-danger"></span>
    </div>
    @* select option de Fabricante *@
    <div class="form-group">
        <label asp-for="FabricanteId"></label>
        <select asp-for="FabricanteId" class="form-control" asp-items="@(new SelectList(ViewBag.Fabricantes, "Id", "Nombre"))">
            <option value="">Seleccione un fabricante</option>
        </select>
        <span asp-validation-for="FabricanteId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>